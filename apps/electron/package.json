{
  "name": "@rpa/electron",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "out/electron/src/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "dist": "electron-builder",
    "clean": "rimraf out dist"
  },
  "dependencies": {
    "@nut-tree/nut-js": "^4.2.0",
    "better-sqlite3": "^11.0.0",
    "electron": "^28.1.0",
    "playwright": "^1.40.1",
    "reflect-metadata": "^0.2.1",
    "typeorm": "^0.3.17",
    "edge-js": "^21.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.rpa.robot",
    "productName": "Windows RPA Robot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
